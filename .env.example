# Copy to .env and fill in real values. NEVER commit .env.

# ---- App ----
NODE_ENV=production
APP_URL=https://app.my-repair.it
TRACKING_URL=https://t.my-repair.it
NEXTAUTH_URL=https://app.my-repair.it
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me

# ---- Database ----
POSTGRES_PASSWORD=replace_me_strong_password
DATABASE_URL=postgresql://repair:replace_me_strong_password@postgres:5432/repair

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- MinIO / S3 ----
MINIO_ROOT_USER=repair_admin
MINIO_ROOT_PASSWORD=replace_me_strong_password
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://cdn.my-repair.it
S3_REGION=us-east-1
S3_ACCESS_KEY=repair_admin
S3_SECRET_KEY=replace_me_strong_password
S3_BUCKET_PUBLIC=repair-public-readonly
S3_BUCKET_PRIVATE=repair-private

# ---- Email (SMTP) ----
# Provider consigliati: Brevo (Sendinblue), Mailjet, AWS SES, Postfix self-hosted
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Repair <noreply@my-repair.it>"

# ---- AI (Phase 3) ----
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Telegram bot (Phase 3) ----
# TELEGRAM_BOT_TOKEN=

# ---- Backup ----
# RESTIC_REPO=sftp:user@storagebox.your-storagebox.de:/repair
# RESTIC_PASSWORD=replace_me
